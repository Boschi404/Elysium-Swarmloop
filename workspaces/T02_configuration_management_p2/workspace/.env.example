# ── T02 — Docker Compose: Full Stack ──────────────────
# Environment variables — copy to .env and fill secrets
#   cp .env.example .env
# ──────────────────────────────────────────────────────

# ── Mandatory Secrets (no defaults — will fail fast) ──
POSTGRES_PASSWORD=changeme_secure_password_123
REDIS_PASSWORD=changeme_secure_redis_456
SECRET_KEY=changeme_super_secret_jwt_key_789

# ── App ───────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=info
CORS_ORIGINS=https://example.com

# ── PostgreSQL ────────────────────────────────────────
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ── Nginx ─────────────────────────────────────────────
NGINX_SERVER_NAME=example.com
NGINX_SSL_PORT=443
