# ─── App ───────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=4
APP_NAME=FastAPI Full Stack
APP_DEBUG=false
APP_SECRET_KEY=change-this-to-a-long-random-string
APP_ENVIRONMENT=production
APP_LOG_LEVEL=info
APP_CORS_ORIGINS=*

# ─── Database (PostgreSQL) ─────────────────────────────────────────────────
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=fastapi_app
POSTGRES_USER=app_user
POSTGRES_PASSWORD=change-this-db-password
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_SERVER}:${POSTGRES_PORT}/${POSTGRES_DB}
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_SERVER=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-this-redis-password
REDIS_DB=0
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_SERVER}:${REDIS_PORT}/${REDIS_DB}
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_RETRY_ON_TIMEOUT=true
REDIS_MAX_CONNECTIONS=50

# ─── Nginx ──────────────────────────────────────────────────────────────────
NGINX_HOST=localhost
NGINX_PORT=80
NGINX_SSL_PORT=443
NGINX_SERVER_NAME=_
NGINX_CLIENT_MAX_BODY_SIZE=100M
NGINX_WORKER_PROCESSES=auto
NGINX_KEEPALIVE_TIMEOUT=65
NGINX_PROXY_READ_TIMEOUT=120
NGINX_PROXY_CONNECT_TIMEOUT=30

# ─── SSL / Certbot ─────────────────────────────────────────────────────────
CERTBOT_EMAIL=admin@example.com
CERTBOT_DOMAIN=example.com
CERTBOT_STAGING=true
CERTBOT_RSA_KEY_SIZE=2048
SSL_CERT_PATH=/etc/letsencrypt/live/${CERTBOT_DOMAIN}/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/${CERTBOT_DOMAIN}/privkey.pem

# ─── Health Checks ──────────────────────────────────────────────────────────
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=10s
HEALTHCHECK_RETRIES=3
HEALTHCHECK_START_PERIOD=40s
